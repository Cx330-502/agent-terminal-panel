{
  "name": "agent-terminal-panel",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "1.0.2",
  "publisher": "Cx330-502",
  "author": "Cx330-502",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cx330-502/agent-terminal-panel.git"
  },
  "homepage": "https://github.com/Cx330-502/agent-terminal-panel#readme",
  "bugs": {
    "url": "https://github.com/Cx330-502/agent-terminal-panel/issues"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "agent",
    "ai-agent",
    "cli",
    "codex",
    "claude",
    "terminal",
    "xterm",
    "sidebar",
    "panel",
    "wsl",
    "ssh"
  ],
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": false,
    "untrustedWorkspaces": {
      "supported": false
    }
  },
  "activationEvents": [
    "onView:agentTerminalPanel.terminalView",
    "onCommand:agentTerminalPanel.newSession",
    "onCommand:agentTerminalPanel.newSessionInFolder",
    "onCommand:agentTerminalPanel.newCustomSession",
    "onCommand:agentTerminalPanel.showNewSessionMenu",
    "onCommand:agentTerminalPanel.find",
    "onCommand:agentTerminalPanel.openSessionHistory",
    "onCommand:agentTerminalPanel.restoreWorkspaceSessions",
    "onCommand:agentTerminalPanel.reopenClosedSession",
    "onCommand:agentTerminalPanel.renameSession",
    "onCommand:agentTerminalPanel.closeSession",
    "onCommand:agentTerminalPanel.restartSession",
    "onCommand:agentTerminalPanel.configureLaunchCommand",
    "onCommand:agentTerminalPanel.openSettings",
    "onCommand:agentTerminalPanel.nextSession",
    "onCommand:agentTerminalPanel.previousSession"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "agentTerminalPanel",
          "title": "%viewContainer.title%",
          "icon": "media/sidebar.svg"
        }
      ]
    },
    "views": {
      "agentTerminalPanel": [
        {
          "type": "webview",
          "id": "agentTerminalPanel.terminalView",
          "name": "%view.sessions.name%",
          "contextualTitle": "%view.sessions.contextualTitle%",
          "visibility": "visible"
        },
        {
          "id": "agentTerminalPanel.attachmentInbox",
          "name": "%view.inbox.name%",
          "contextualTitle": "%view.inbox.contextualTitle%",
          "visibility": "collapsed"
        }
      ]
    },
    "commands": [
      {
        "command": "agentTerminalPanel.newSession",
        "title": "%command.newSession%",
        "category": "Agent Terminal Panel",
        "icon": "$(add)"
      },
      {
        "command": "agentTerminalPanel.showNewSessionMenu",
        "title": "%command.showNewSessionMenu%",
        "category": "Agent Terminal Panel",
        "icon": "$(chevron-down)"
      },
      {
        "command": "agentTerminalPanel.find",
        "title": "%command.find%",
        "category": "Agent Terminal Panel",
        "icon": "$(search)"
      },
      {
        "command": "agentTerminalPanel.newSessionInFolder",
        "title": "%command.newSessionInFolder%",
        "category": "Agent Terminal Panel",
        "icon": "$(folder-opened)"
      },
      {
        "command": "agentTerminalPanel.newCustomSession",
        "title": "%command.newCustomSession%",
        "category": "Agent Terminal Panel",
        "icon": "$(terminal)"
      },
      {
        "command": "agentTerminalPanel.openSessionHistory",
        "title": "%command.openSessionHistory%",
        "category": "Agent Terminal Panel",
        "icon": "$(history)"
      },
      {
        "command": "agentTerminalPanel.restoreWorkspaceSessions",
        "title": "%command.restoreWorkspaceSessions%",
        "category": "Agent Terminal Panel",
        "icon": "$(window)"
      },
      {
        "command": "agentTerminalPanel.reopenClosedSession",
        "title": "%command.reopenClosedSession%",
        "category": "Agent Terminal Panel",
        "icon": "$(history)"
      },
      {
        "command": "agentTerminalPanel.renameSession",
        "title": "%command.renameSession%",
        "category": "Agent Terminal Panel",
        "icon": "$(edit)"
      },
      {
        "command": "agentTerminalPanel.closeSession",
        "title": "%command.closeSession%",
        "category": "Agent Terminal Panel"
      },
      {
        "command": "agentTerminalPanel.restartSession",
        "title": "%command.restartSession%",
        "category": "Agent Terminal Panel",
        "icon": "$(debug-restart)"
      },
      {
        "command": "agentTerminalPanel.configureLaunchCommand",
        "title": "%command.configureLaunchCommand%",
        "category": "Agent Terminal Panel"
      },
      {
        "command": "agentTerminalPanel.openSettings",
        "title": "%command.openSettings%",
        "category": "Agent Terminal Panel",
        "icon": "$(settings-gear)"
      },
      {
        "command": "agentTerminalPanel.nextSession",
        "title": "%command.nextSession%",
        "category": "Agent Terminal Panel"
      },
      {
        "command": "agentTerminalPanel.previousSession",
        "title": "%command.previousSession%",
        "category": "Agent Terminal Panel"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentTerminalPanel.newSession",
          "when": "view == agentTerminalPanel.terminalView",
          "group": "navigation@1"
        },
        {
          "command": "agentTerminalPanel.restartSession",
          "when": "view == agentTerminalPanel.terminalView",
          "group": "navigation@3"
        },
        {
          "command": "agentTerminalPanel.openSettings",
          "when": "view == agentTerminalPanel.terminalView",
          "group": "navigation@4"
        }
      ]
    },
    "keybindings": [
      {
        "command": "agentTerminalPanel.newSession",
        "key": "ctrl+shift+`",
        "mac": "cmd+shift+`",
        "when": "focusedView == agentTerminalPanel.terminalView"
      },
      {
        "command": "agentTerminalPanel.find",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "focusedView == agentTerminalPanel.terminalView"
      },
      {
        "command": "agentTerminalPanel.nextSession",
        "key": "ctrl+pagedown",
        "mac": "cmd+alt+right",
        "when": "focusedView == agentTerminalPanel.terminalView"
      },
      {
        "command": "agentTerminalPanel.previousSession",
        "key": "ctrl+pageup",
        "mac": "cmd+alt+left",
        "when": "focusedView == agentTerminalPanel.terminalView"
      },
      {
        "command": "agentTerminalPanel.closeSession",
        "key": "ctrl+w",
        "mac": "cmd+w",
        "when": "focusedView == agentTerminalPanel.terminalView"
      },
      {
        "command": "agentTerminalPanel.reopenClosedSession",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "focusedView == agentTerminalPanel.terminalView"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "agentTerminalPanel.launchCommand": {
          "type": "string",
          "default": "",
          "description": "%configuration.launchCommand.description%"
        },
        "agentTerminalPanel.launchProfiles": {
          "type": "array",
          "default": [],
          "description": "%configuration.launchProfiles.description%",
          "items": {
            "type": "object",
            "required": [
              "name",
              "command"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "description": "%configuration.launchProfiles.name.description%"
              },
              "command": {
                "type": "string",
                "minLength": 1,
                "description": "%configuration.launchProfiles.command.description%"
              }
            }
          }
        },
        "agentTerminalPanel.environment": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "description": "%configuration.environment.description%"
        },
        "agentTerminalPanel.sessionListPosition": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "enumDescriptions": [
            "%configuration.sessionListPosition.left%",
            "%configuration.sessionListPosition.right%"
          ],
          "default": "left",
          "description": "%configuration.sessionListPosition.description%"
        },
        "agentTerminalPanel.startSessionOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.startSessionOnOpen.description%"
        },
        "agentTerminalPanel.terminalImages.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.terminalImages.enabled.description%"
        },
        "agentTerminalPanel.communicationHealth.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.communicationHealth.enabled.description%"
        },
        "agentTerminalPanel.communicationHealth.sampleIntervalMs": {
          "type": "number",
          "default": 2000,
          "minimum": 500,
          "maximum": 10000,
          "description": "%configuration.communicationHealth.sampleIntervalMs.description%"
        },
        "agentTerminalPanel.communicationHealth.quietThresholdSeconds": {
          "type": "number",
          "default": 15,
          "minimum": 5,
          "maximum": 300,
          "description": "%configuration.communicationHealth.quietThresholdSeconds.description%"
        },
        "agentTerminalPanel.communicationHealth.stalledThresholdSeconds": {
          "type": "number",
          "default": 45,
          "minimum": 10,
          "maximum": 600,
          "description": "%configuration.communicationHealth.stalledThresholdSeconds.description%"
        },
        "agentTerminalPanel.communicationHealth.processNetwork.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.communicationHealth.processNetwork.enabled.description%"
        },
        "agentTerminalPanel.communicationHealth.codexSessionMetrics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.communicationHealth.codexSessionMetrics.enabled.description%"
        },
        "agentTerminalPanel.sessionHistory.maxResults": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "maximum": 500,
          "description": "%configuration.sessionHistory.maxResults.description%"
        },
        "agentTerminalPanel.sessionHistory.codexCommand": {
          "type": "string",
          "default": "codex",
          "description": "%configuration.sessionHistory.codexCommand.description%"
        },
        "agentTerminalPanel.sessionHistory.claudeCommand": {
          "type": "string",
          "default": "claude",
          "description": "%configuration.sessionHistory.claudeCommand.description%"
        },
        "agentTerminalPanel.notifications.showToast": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.notifications.showToast.description%"
        },
        "agentTerminalPanel.notifications.completionSound": {
          "type": "string",
          "enum": [
            "never",
            "whenHidden",
            "always"
          ],
          "enumDescriptions": [
            "%configuration.notifications.completionSound.never%",
            "%configuration.notifications.completionSound.whenHidden%",
            "%configuration.notifications.completionSound.always%"
          ],
          "default": "whenHidden",
          "description": "%configuration.notifications.completionSound.description%"
        }
      }
    }
  },
  "scripts": {
    "check": "tsc --noEmit",
    "build": "npm run check && node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test": "node --import tsx --test test/*.test.ts",
    "test:browser": "npm run build && node test/runBrowserRegressions.mjs",
    "verify": "npm run build && npm test && npm run test:browser",
    "vscode:prepublish": "npm run build",
    "package": "npm run package:all",
    "package:all": "npm run build && node scripts/package.mjs"
  },
  "dependencies": {
    "node-pty": "1.2.0-beta.13"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.106.0",
    "@vscode/vsce": "^3.9.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "0.9.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "esbuild": "^0.25.0",
    "playwright": "^1.61.1",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
